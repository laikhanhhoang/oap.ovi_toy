  "pageEvents": [
    {
      "name": "delete_patient_event",
      "trigger": "onCustomAction",
      "sourceComponent": "delete_patient",
      "actions": [
        {
          "type": "confirm",
          "message": "Bạn có chắc chắn muốn xóa bệnh nhân này không?"
        },
        {
          "type": "command",
          "commandMode": "plsql",
          "query": "BEGIN UPDATE DEMO_PATIENTS SET IS_DELETED = 1 WHERE PATIENT_ID = :p_patient_id; END;",
          "body": {
            "bindVariables": [
              {
                "name": "p_patient_id",
                "value": "{{PATIENT_ID}}"
              }
            ]
          },
          "onResult": [
            {
              "type": "showMessage",
              "messageType": "success",
              "message": "Đã xóa bệnh nhân thành công!"
            },
            {
              "type": "navigate",
              "url": "/page/HD_PATIENTS_LIST"
            }
          ],
          "onError": [
            {
              "type": "showMessage",
              "messageType": "error",
              "message": "Có lỗi xảy ra khi xóa bệnh nhân."
