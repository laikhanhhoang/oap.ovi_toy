{
    "metadataVersion": 2,
    "pageCode": "HD_PATIENT_DETAIL",
    "pageType": "form",
    "title": "Thông tin chi tiết Bệnh nhân",
    "description": "Form thông tin chi tiết bệnh nhân",
    "dataSource": {
        "type": "query",
        "keyField": "PATIENT_ID",
        "loadQuery": "SELECT PATIENT_ID, PATIENT_CODE, FIRST_NAME, LAST_NAME, DATE_OF_BIRTH, GENDER, PHONE_NUMBER, EMAIL, ADDRESS, IDENTITY_NUMBER, BLOOD_TYPE, ALLERGIES, INSURANCE_NUMBER, INSURANCE_PROVIDER, STATUS, CREATED_BY, CREATED_DATE FROM DEMO_PATIENTS WHERE PATIENT_ID = :id",
        "params": [
            { "name": "id", "sourceType": "url", "sourceField": "id" }
        ],
        "saveQuery": "DECLARE\n  v_dob DATE;\nBEGIN\n  IF :p_date_of_birth IS NOT NULL AND :p_date_of_birth != '' THEN\n    IF REGEXP_LIKE(:p_date_of_birth, '^\\d{4}-\\d{2}-\\d{2}') THEN\n      v_dob := TO_DATE(SUBSTR(:p_date_of_birth, 1, 10), 'YYYY-MM-DD');\n    ELSIF REGEXP_LIKE(:p_date_of_birth, '^\\d{2}/\\d{2}/\\d{4}') THEN\n      v_dob := TO_DATE(SUBSTR(:p_date_of_birth, 1, 10), 'DD/MM/YYYY');\n    ELSIF REGEXP_LIKE(:p_date_of_birth, '^\\d{4}/\\d{2}/\\d{2}') THEN\n      v_dob := TO_DATE(SUBSTR(:p_date_of_birth, 1, 10), 'YYYY/MM/DD');\n    END IF;\n  END IF;\n\n  UPDATE DEMO_PATIENTS\n     SET PATIENT_CODE       = :p_patient_code,\n         FIRST_NAME         = :p_first_name,\n         LAST_NAME          = :p_last_name,\n         DATE_OF_BIRTH      = NVL(v_dob, DATE_OF_BIRTH),\n         GENDER             = :p_gender,\n         PHONE_NUMBER       = :p_phone_number,\n         EMAIL              = :p_email,\n         ADDRESS            = :p_address,\n         IDENTITY_NUMBER    = :p_identity_number,\n         BLOOD_TYPE         = :p_blood_type,\n         ALLERGIES          = :p_allergies,\n         INSURANCE_NUMBER   = :p_insurance_number,\n         INSURANCE_PROVIDER = :p_insurance_provider\n   WHERE PATIENT_ID = COALESCE(:p_patient_id, :id);\nEND;"
    },
    "layout": {
        "type": "splitter",
        "panes": [
            {
