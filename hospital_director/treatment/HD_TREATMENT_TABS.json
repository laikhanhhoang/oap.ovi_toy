{
  "metadataVersion": 2,
  "pageCode": "HD_TREATMENT_TABS",
  "pageType": "form",
  "title": "Thông tin chi tiết Đợt Điều trị",
  "description": "Form thông tin chi tiết đợt điều trị",
  "dataSource": {
    "type": "query",
    "keyField": "TREATMENT_ID",
    "tableName": "DEMO_TREATMENTS",
    "loadQuery": "SELECT TREATMENT_ID, TREATMENT_CODE, MEDICAL_RECORD_ID, PATIENT_ID, DOCTOR_ID, ROOM_ID, BED_NUMBER, TREATMENT_TYPE, DESCRIPTION, START_DATE, END_DATE, COST, STATUS, CREATED_BY, CREATED_DATE FROM DEMO_TREATMENTS WHERE TREATMENT_ID = :id",
    "params": [
      {
        "name": "id",
        "sourceType": "url",
        "sourceField": "id"
      }
    ],
    "saveQuery": "DECLARE\n  v_start_date DATE;\n  v_end_date DATE;\n  v_start_str VARCHAR2(100) := TRIM(:p_start_date);\n  v_end_str VARCHAR2(100) := TRIM(:p_end_date);\nBEGIN\n  -- Parse START_DATE\n  IF v_start_str IS NOT NULL THEN\n    IF REGEXP_LIKE(v_start_str, '^\\d{4}[-/]\\d{2}[-/]\\d{2}') THEN\n      v_start_date := TO_DATE(SUBSTR(v_start_str, 1, 10), CASE WHEN SUBSTR(v_start_str, 5, 1) = '/' THEN 'YYYY/MM/DD' ELSE 'YYYY-MM-DD' END);\n    ELSIF REGEXP_LIKE(v_start_str, '^\\d{2}[-/]\\d{2}[-/]\\d{4}') THEN\n      v_start_date := TO_DATE(SUBSTR(v_start_str, 1, 10), CASE WHEN SUBSTR(v_start_str, 3, 1) = '/' THEN 'DD/MM/YYYY' ELSE 'DD-MM-YYYY' END);\n    ELSE\n      BEGIN\n        v_start_date := TO_DATE(SUBSTR(v_start_str, 1, 10), 'YYYY-MM-DD');\n      EXCEPTION WHEN OTHERS THEN\n        BEGIN\n          v_start_date := TO_DATE(SUBSTR(v_start_str, 1, 10), 'DD/MM/YYYY');\n        EXCEPTION WHEN OTHERS THEN\n          v_start_date := NULL;\n        END;\n      END;\n    END IF;\n  END IF;\n  v_start_date := NVL(v_start_date, TRUNC(SYSDATE));\n\n  -- Parse END_DATE\n  IF v_end_str IS NOT NULL THEN\n    IF REGEXP_LIKE(v_end_str, '^\\d{4}[-/]\\d{2}[-/]\\d{2}') THEN\n      v_end_date := TO_DATE(SUBSTR(v_end_str, 1, 10), CASE WHEN SUBSTR(v_end_str, 5, 1) = '/' THEN 'YYYY/MM/DD' ELSE 'YYYY-MM-DD' END);\n    ELSIF REGEXP_LIKE(v_end_str, '^\\d{2}[-/]\\d{2}[-/]\\d{4}') THEN\n      v_end_date := TO_DATE(SUBSTR(v_end_str, 1, 10), CASE WHEN SUBSTR(v_end_str, 3, 1) = '/' THEN 'DD/MM/YYYY' ELSE 'DD-MM-YYYY' END);\n    ELSE\n      BEGIN\n        v_end_date := TO_DATE(SUBSTR(v_end_str, 1, 10), 'YYYY-MM-DD');\n      EXCEPTION WHEN OTHERS THEN\n        BEGIN\n          v_end_date := TO_DATE(SUBSTR(v_end_str, 1, 10), 'DD/MM/YYYY');\n        EXCEPTION WHEN OTHERS THEN\n          v_end_date := NULL;\n        END;\n      END;\n    END IF;\n  END IF;\n\n  UPDATE DEMO_TREATMENTS\n     SET MEDICAL_RECORD_ID = :p_medical_record_id,\n         PATIENT_ID        = :p_patient_id,\n         DOCTOR_ID         = :p_doctor_id,\n         ROOM_ID           = :p_room_id,\n         BED_NUMBER        = :p_bed_number,\n         TREATMENT_TYPE    = :p_treatment_type,\n         DESCRIPTION       = :p_description,\n         START_DATE        = v_start_date,\n         END_DATE          = v_end_date,\n         COST              = NVL(:p_cost, 0),\n         STATUS            = NVL(:p_status, STATUS)\n   WHERE TREATMENT_ID = COALESCE(:p_treatment_id, :id);\nEND;"
  },
