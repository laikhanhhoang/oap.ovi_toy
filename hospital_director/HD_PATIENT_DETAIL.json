{
  "metadataVersion": 2,
  "pageCode": "HD_PATIENT_DETAIL",
  "pageType": "form",
  "title": "Thông tin chi tiết Bệnh nhân",
  "description": "Form thông tin chi tiết bệnh nhân",
  "dataSource": {
    "type": "query",
    "keyField": "PATIENT_ID",
    "tableName": "DEMO_PATIENTS",
    "loadQuery": "SELECT PATIENT_ID, PATIENT_CODE, FIRST_NAME, LAST_NAME, DATE_OF_BIRTH, GENDER, PHONE_NUMBER, EMAIL, ADDRESS, IDENTITY_NUMBER, BLOOD_TYPE, ALLERGIES, INSURANCE_NUMBER, INSURANCE_PROVIDER, STATUS, CREATED_BY, CREATED_DATE FROM DEMO_PATIENTS WHERE PATIENT_ID = :id AND NVL(IS_DELETED, 0) = 0",
    "params": [
      {
        "name": "id",
        "sourceType": "url",
        "sourceField": "id"
      }
    ],
    "saveQuery": "DECLARE\n  v_dob DATE;\n  v_str VARCHAR2(100) := TRIM(:p_date_of_birth);\n  v_gender VARCHAR2(20) := :p_gender;\nBEGIN\n  IF v_str IS NOT NULL THEN\n    IF REGEXP_LIKE(v_str, '^\\d{4}[-/]\\d{2}[-/]\\d{2}') THEN\n      v_dob := TO_DATE(SUBSTR(v_str, 1, 10), CASE WHEN SUBSTR(v_str, 5, 1) = '/' THEN 'YYYY/MM/DD' ELSE 'YYYY-MM-DD' END);\n    ELSIF REGEXP_LIKE(v_str, '^\\d{2}[-/]\\d{2}[-/]\\d{4}') THEN\n      v_dob := TO_DATE(SUBSTR(v_str, 1, 10), CASE WHEN SUBSTR(v_str, 3, 1) = '/' THEN 'DD/MM/YYYY' ELSE 'DD-MM-YYYY' END);\n    ELSE\n      BEGIN\n        v_dob := TO_DATE(SUBSTR(v_str, 1, 10), 'YYYY-MM-DD');\n      EXCEPTION WHEN OTHERS THEN\n        BEGIN\n          v_dob := TO_DATE(SUBSTR(v_str, 1, 10), 'DD/MM/YYYY');\n        EXCEPTION WHEN OTHERS THEN\n          v_dob := NULL;\n        END;\n      END;\n    END IF;\n  END IF;\n\n  IF v_gender IN ('MALE', 'Nam', 'M') THEN v_gender := 'M';\n  ELSIF v_gender IN ('FEMALE', 'Nữ', 'F') THEN v_gender := 'F';\n  ELSIF v_gender IS NOT NULL THEN v_gender := 'O';\n  END IF;\n\n  UPDATE DEMO_PATIENTS\n     SET PATIENT_CODE       = :p_patient_code,\n         FIRST_NAME         = :p_first_name,\n         LAST_NAME          = :p_last_name,\n         DATE_OF_BIRTH      = NVL(v_dob, DATE_OF_BIRTH),\n         GENDER             = v_gender,\n         PHONE_NUMBER       = :p_phone_number,\n         EMAIL              = :p_email,\n         ADDRESS            = :p_address,\n         IDENTITY_NUMBER    = :p_identity_number,\n         BLOOD_TYPE         = :p_blood_type,\n         ALLERGIES          = :p_allergies,\n         INSURANCE_NUMBER   = :p_insurance_number,\n         INSURANCE_PROVIDER = :p_insurance_provider,\n         STATUS             = NVL(:p_status, STATUS)\n   WHERE PATIENT_ID = COALESCE(:p_patient_id, :id);\nEND;"
  },
