            "col": 1,
            "colSpan": 1
          }
        },
        {
          "name": "card_parent_groups",
          "type": "card-region",
          "displayAs": "card-grid",
          "layout": {
            "col": 2,
            "colSpan": 11
          },
          "config": {
            "titleField": "RPG_NAME",
            "subtitleField": "DESCRIPTION",
            "colSpan": 4
          },
          "data": {
            "type": "query",
            "query": "SELECT RPG_ID, RPG_NAME, DESCRIPTION FROM ERP.RE_PRODUCT_GROUPS WHERE PARENT_RPG_ID IS NULL AND STATUS = 'Y' ORDER BY RPG_ID"
          }
        }
      ]
