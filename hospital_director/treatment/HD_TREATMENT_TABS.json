  "pageEvents": [
    {
      "name": "delete_treatment_event",
      "trigger": "onCustomAction",
      "sourceComponent": "delete_treatment",
      "actions": [
        {
          "type": "confirm",
          "message": "Bạn có chắc chắn muốn xóa đợt điều trị này không?"
        },
        {
          "type": "command",
          "commandMode": "plsql",
          "query": "BEGIN DELETE FROM DEMO_TREATMENTS WHERE TREATMENT_ID = :p_treatment_id; END;",
          "body": {
            "bindVariables": [
              {
                "name": "p_treatment_id",
                "value": "{{TREATMENT_ID}}"
              }
            ]
          },
          "onResult": [
            {
              "type": "showMessage",
              "messageType": "success",
              "message": "Đã xóa đợt điều trị thành công!"
            },
            {
              "type": "navigate",
              "url": "/page/HD_TREATMENTS_LIST"
            }
          ],
          "onError": [
            {
              "type": "showMessage",
              "messageType": "error",
              "message": "Có lỗi xảy ra khi xóa đợt điều trị."
            }
          ]
        }
      ]
    }
